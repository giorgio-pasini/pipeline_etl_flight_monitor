# Copier en `.env` pour surcharger (optionnel — le pipeline tourne sans).
#   cp .env.example .env

# Identifiants FlightRadar24 — quota API plus élevé. Vide = mode anonyme.
FR24_EMAIL=
FR24_PASSWORD=

# Mémoire du driver Spark (mode local). Augmenter si gros volumes.
# Astuce : allouer >= 4 Go à Docker Desktop pour confort.
SPARK_DRIVER_MEMORY=2g

# Jeu aéroports OpenFlights — auto-géré (téléchargé si absent, rafraîchi à 14 j).
# Décommenter pour changer le TTL ou la source :
# DIM_AIRPORTS_MAX_AGE_DAYS=14
# DIM_AIRPORTS_STATIC_URL=https://raw.githubusercontent.com/jpatokal/openflights/master/data/airports.dat

# Orchestration Airflow (profil "airflow") : `airflow standalone` génère un mot de passe
# admin au 1er démarrage -> visible dans les logs du conteneur, ou dans le fichier
# /opt/airflow/simple_auth_manager_passwords.json.generated. Login : admin.
